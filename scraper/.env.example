# Scraper — fills Supabase with shop prices.
# Copy to .env and fill in your keys.

SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
OPENAI_API_KEY=YOUR-OPENAI-KEY
GITHUB_TOKEN=YOUR-GITHUB-TOKEN
# Optional dedicated token for cron-job.org (fine-grained PAT, actions:write on this repo):
# CRON_DISPATCH_TOKEN=YOUR-PAT
# Required once for auto-deploy (scripts/setup_vercel.py):
VERCEL_TOKEN=YOUR-VERCEL-TOKEN
# Optional fallback only if the daily rate fetch fails:
# EUR_TO_HUF_RATE=395
SUPABASE_LISTINGS_TABLE=shop_listings
MIN_EXPECTED_PRODUCTS=30
