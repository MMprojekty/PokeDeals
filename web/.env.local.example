# Copy this file to .env.local and fill in your Supabase keys.

SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_LISTINGS_TABLE=shop_listings

# Public site URL for SEO (sitemap, canonical links, Open Graph).
NEXT_PUBLIC_SITE_URL=https://pokedeals.hu
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co

# Optional — only needed for Vercel CLI setup (scripts/setup_vercel.py).
# VERCEL_TOKEN=
